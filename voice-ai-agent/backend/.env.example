# ===== OpenAI =====
# Required. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Realtime model. Newest as of 2024-12 GA release.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# OpenAI voice: alloy | ash | ballad | coral | echo | sage | shimmer | verse
OPENAI_VOICE=shimmer

# ===== Voice provider switch =====
# 'openai'      = OpenAI speaks directly (default, lowest latency)
# 'elevenlabs'  = OpenAI returns text only, ElevenLabs TTS speaks it (future)
VOICE_PROVIDER=openai

# ===== ElevenLabs (only if VOICE_PROVIDER=elevenlabs) =====
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ===== Server =====
HOST=0.0.0.0
PORT=8000
FRONTEND_ORIGIN=http://localhost:8000
